# CODA 웹 애플리케이션 환경 설정

# 서버 포트
PORT=5001

# 프론트엔드 포트 (Vite)
VITE_PORT=3002

# 백엔드 API URL
VITE_API_URL=http://localhost:5001

# 노드 환경
NODE_ENV=development

# 로깅 레벨
LOG_LEVEL=info

# 캐시 설정
CACHE_ENABLED=true
CACHE_TTL=3600

# Python 크롤러 설정
CRAWLER_ENABLED=false
CRAWLER_TIMEOUT=30000

# 데이터베이스 (향후)
# DB_HOST=localhost
# DB_PORT=27017
# DB_NAME=coda_outreach
